{
  "name": "monopoly-server",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:integration": "(cd .. && supabase start && supabase db reset) && jest --testPathPatterns=integration --runInBand"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "setupFiles": ["<rootDir>/__tests__/integration/env-setup.js"]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.5",
    "body-parser": "^1.20.2",
    "express": "^4.19.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.3",
    "supertest": "^7.2.2"
  }
}
